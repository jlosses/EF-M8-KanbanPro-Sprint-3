<div class="home-container">
  {{#if usuario}}
    <div class="welcome-section">
      <h1>¡Bienvenido de vuelta, {{usuario.email}}!</h1>
      <p>Tu aplicación de gestión de proyectos Kanban está lista para usar.</p>
      <a href="/dashboard" class="cta-button">Ir al Dashboard</a>
    </div>
  {{else}}
    <div class="welcome-section">
      <h1>Bienvenido a KanbanPro</h1>
      <p>La plataforma moderna para gestionar tus proyectos con metodología Kanban.</p>
      
      <div class="features">
        <h2>Características</h2>
        <ul>
          <li>📋 Organiza tus tableros de proyectos</li>
          <li>✅ Gestiona tareas en diferentes estados</li>
          <li>👥 Colaboración segura con autenticación JWT</li>
          <li>🔒 Tus datos siempre protegidos</li>
        </ul>
      </div>

      <div class="cta-section">
        <p>¿Listo para comenzar?</p>
        <div class="button-group">
          <a href="/registro" class="cta-button primary">Crear Cuenta</a>
          <a href="/login" class="cta-button secondary">Iniciar Sesión</a>
        </div>
      </div>
    </div>
  {{/if}}
</div>

<style>
  .home-container {
    max-width: 800px;
    margin: 60px auto;
    text-align: center;
    padding: 20px;
  }

  .welcome-section h1 {
    font-size: 2.5em;
    color: #007bff;
    margin-bottom: 20px;
  }

  .welcome-section > p {
    font-size: 1.2em;
    color: #666;
    margin-bottom: 30px;
  }

  .features {
    background-color: #f9f9f9;
    border-radius: 8px;
    padding: 30px;
    margin: 30px 0;
    text-align: left;
  }

  .features h2 {
    color: #007bff;
    margin-bottom: 20px;
  }

  .features ul {
    list-style: none;
  }

  .features li {
    padding: 10px 0;
    font-size: 1.1em;
    color: #333;
  }

  .cta-section {
    margin-top: 40px;
  }

  .cta-section p {
    font-size: 1.3em;
    color: #333;
    margin-bottom: 20px;
  }

  .button-group {
    display: flex;
    gap: 20px;
    justify-content: center;
  }

  .cta-button {
    display: inline-block;
    padding: 12px 30px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.3s ease;
  }

  .cta-button.primary {
    background-color: #007bff;
    color: white;
  }

  .cta-button.primary:hover {
    background-color: #0056b3;
  }

  .cta-button.secondary {
    background-color: #6c757d;
    color: white;
  }

  .cta-button.secondary:hover {
    background-color: #545b62;
  }
</style>