<h1>Dashboard - KanbanPro</h1>

{{#if error}}
  <div class="error-message">
    <p>{{error}}</p>
  </div>
{{/if}}

<div class="dashboard-container">
  <!-- Sección para crear nuevo tablero -->
  <section class="create-board">
    <h2>Crear Nuevo Tablero</h2>
    <form action="/crear-tablero" method="POST" class="form-tablero">
      <input type="text" name="titulo" placeholder="Título del tablero" required>
      <textarea name="descripcion" placeholder="Descripción (opcional)"></textarea>
      <button type="submit">Crear Tablero</button>
    </form>
  </section>

  <!-- Tableros y contenido -->
  {{#if tableros}}
    <div class="tableros-container">
      {{#each tableros}}
        <div class="tablero">
          <h2>{{titulo}}</h2>
          {{#if descripcion}}<p class="tablero-desc">{{descripcion}}</p>{{/if}}

          <!-- Sección para crear nueva lista -->
          <div class="create-list">
            <form action="/crear-lista" method="POST" class="form-lista">
              <input type="hidden" name="tableroId" value="{{id}}">
              <input type="text" name="titulo" placeholder="Nombre de la lista" required>
              <button type="submit">+ Nueva Lista</button>
            </form>
          </div>

          <!-- Listas del tablero -->
          <div class="listas-container">
            {{#if listas}}
              {{#each listas}}
                <div class="lista">
                  <h3>{{titulo}}</h3>
                  
                  <!-- Formulario para crear nueva tarjeta -->
                  <div class="create-card">
                    <form action="/nueva-tarjeta" method="POST" class="form-tarjeta">
                      <input type="hidden" name="listId" value="{{id}}">
                      <input type="text" name="title" placeholder="Título de la tarjeta" required>
                      <textarea name="description" placeholder="Descripción"></textarea>
                      <button type="submit">+ Tarjeta</button>
                    </form>
                  </div>

                  <!-- Tarjetas de la lista -->
                  <div class="tarjetas-container">
                    {{#each tarjetas}}
                      <div class="tarjeta">
                        <h4>{{titulo}}</h4>
                        {{#if descripcion}}<p>{{descripcion}}</p>{{/if}}
                      </div>
                    {{else}}
                      <p class="empty-message">No hay tarjetas en esta lista</p>
                    {{/each}}
                  </div>
                </div>
              {{/each}}
            {{else}}
              <p class="empty-message">No hay listas en este tablero. ¡Crea una!</p>
            {{/if}}
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>No tienes tableros aún. ¡Crea tu primer tablero!</p>
    </div>
  {{/if}}
</div>

<style>
  .dashboard-container {
    max-width: 1200px;
    margin: 20px auto;
    padding: 20px;
  }

  .create-board {
    background-color: #f5f5f5;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 30px;
  }

  .form-tablero, .form-lista, .form-tarjeta {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-tablero input, .form-tablero textarea {
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 4px;
  }

  .tableros-container {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .tablero {
    border: 2px solid #007bff;
    border-radius: 8px;
    padding: 20px;
    background-color: #f9f9f9;
  }

  .tablero h2 {
    margin-top: 0;
    color: #007bff;
  }

  .tablero-desc {
    color: #666;
    font-size: 0.95em;
  }

  .create-list {
    background-color: white;
    padding: 15px;
    border: 1px dashed #ccc;
    border-radius: 4px;
    margin: 15px 0;
  }

  .form-lista {
    display: flex;
    gap: 10px;
  }

  .form-lista input {
    flex: 1;
    padding: 8px;
    border: 1px solid #ddd;
    border-radius: 4px;
  }

  .form-lista button {
    padding: 8px 15px;
    background-color: #28a745;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }

  .listas-container {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    padding: 10px 0;
  }

  .lista {
    background-color: #e9ecef;
    border-radius: 4px;
    padding: 15px;
    min-width: 300px;
    max-width: 300px;
  }

  .lista h3 {
    margin-top: 0;
    color: #333;
  }

  .create-card {
    background-color: white;
    padding: 10px;
    border-radius: 4px;
    margin-bottom: 15px;
  }

  .form-tarjeta {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-tarjeta input, .form-tarjeta textarea {
    padding: 8px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .form-tarjeta button {
    padding: 6px;
    background-color: #ffc107;
    color: black;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
  }

  .tarjetas-container {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tarjeta {
    background-color: white;
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 12px;
    cursor: move;
  }

  .tarjeta h4 {
    margin: 0 0 8px 0;
    color: #333;
  }

  .tarjeta p {
    margin: 0;
    color: #666;
    font-size: 0.9em;
  }

  .empty-message {
    color: #999;
    font-style: italic;
    padding: 20px;
  }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    background-color: #f5f5f5;
    border-radius: 8px;
  }

  .error-message {
    background-color: #f8d7da;
    color: #721c24;
    padding: 12px;
    border-radius: 4px;
    margin-bottom: 20px;
  }
</style>