<div class="error-container">
  <div class="error-content">
    <h1>❌ Error</h1>
    {{#if error}}
      <p class="error-message">{{error}}</p>
    {{else}}
      <p class="error-message">Algo salió mal. Por favor, intenta nuevamente.</p>
    {{/if}}
    <a href="/" class="btn-home">Volver al Inicio</a>
  </div>
</div>

<style>
  .error-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .error-content {
    background: white;
    border-radius: 8px;
    padding: 50px;
    text-align: center;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    max-width: 500px;
  }

  .error-content h1 {
    color: #dc3545;
    margin-bottom: 20px;
    font-size: 2.5em;
  }

  .error-message {
    color: #666;
    margin-bottom: 30px;
    font-size: 1.1em;
    line-height: 1.6;
  }

  .btn-home {
    display: inline-block;
    background-color: #007bff;
    color: white;
    padding: 12px 30px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }

  .btn-home:hover {
    background-color: #0056b3;
  }
</style>